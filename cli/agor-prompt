#!/usr/bin/env bash
set -euo pipefail

# Agor session prompt — send a prompt to an Agor session via REST API
# The session will execute it immediately if idle, or queue it if busy.

DAEMON_URL="${AGOR_DAEMON_URL:-http://localhost:3031}"
AGOR_TOKEN="${AGOR_TOKEN:-YOUR_AGOR_TOKEN_HERE}"

usage() {
  cat <<'EOF'
Usage: agor-prompt <session-id> <prompt>

Send a prompt to an Agor session via the daemon REST API.
If the session is idle, it executes immediately.
If the session is busy, it gets queued and runs when the session becomes idle.

Arguments:
  session-id    Agor session ID (full UUID or short ID)
  prompt        The prompt text to send

Environment:
  AGOR_DAEMON_URL   Daemon URL (default: http://localhost:3031)
  AGOR_TOKEN        JWT auth token (has a built-in default for local use)

Examples:
  agor-prompt 278c8b53 "Run the tests and report results"
  agor-prompt 278c8b53-bc77-4d74-9e83-9d151b59b9d7 "Check /tmp/runner.log for output"

  # Use in nohup for background task completion notifications:
  nohup bash -c 'long_task; agor-prompt SESSION_ID "Task done"' &
EOF
  exit 1
}

if [[ $# -lt 2 ]]; then
  usage
fi

SESSION_ID="$1"
shift
PROMPT="$*"

# Escape the prompt for JSON
PROMPT_JSON=$(printf '%s' "$PROMPT" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null || printf '"%s"' "$PROMPT")

RESPONSE=$(curl -sf -X POST "${DAEMON_URL}/sessions/${SESSION_ID}/prompt" \
  -H "Authorization: Bearer ${AGOR_TOKEN}" \
  -H "Content-Type: application/json" \
  -d "{\"prompt\":${PROMPT_JSON},\"stream\":true}" 2>&1) || {
  echo "ERROR: Failed to prompt session ${SESSION_ID}" >&2
  echo "$RESPONSE" >&2
  exit 1
}

# Parse response
if echo "$RESPONSE" | python3 -c 'import sys,json; d=json.load(sys.stdin); print("queued" if d.get("queued") else "executing")' 2>/dev/null; then
  QUEUED=$(echo "$RESPONSE" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("queued",""))' 2>/dev/null)
  if [[ "$QUEUED" == "True" ]]; then
    POS=$(echo "$RESPONSE" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("queue_position","?"))' 2>/dev/null)
    echo "Queued (position ${POS}) — session is busy, will execute when idle"
  else
    echo "Prompt sent — session is executing"
  fi
else
  echo "$RESPONSE"
fi
